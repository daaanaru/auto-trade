# Anthropic API Key（AI戦略生成・cli.py で使用）
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Discord Webhook URL（notifier.py / monitoring_agent.py で使用）
# BUYシグナル、トレード実行、ポートフォリオ更新、卒業判定を通知
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url

# Google Calendar 認証情報（オプション。BUYシグナル時にカレンダー予定を追加）
# google-api-python-client + OAuth2 の credentials.json パスを指定
# GOOGLE_CALENDAR_CREDENTIALS=/path/to/credentials.json

# LocalLLMClient のパス（monitoring_agent.py で使用）
# AUTOMATION_PATH=/path/to/automation

# ===== Live Trade 設定（live_trade.py で使用） =====
# 取引所（bitflyer / gmocoin）
LIVE_TRADE_EXCHANGE=bitflyer

# APIキー（取引所で発行）
LIVE_TRADE_API_KEY=your-api-key-here
LIVE_TRADE_API_SECRET=your-api-secret-here

# DRY_RUNモード（true=注文をシミュレートのみ、false=実際に発注）
# ※ 初めて使うときは必ず true のままテストしてください
LIVE_TRADE_DRY_RUN=true

# 1回の注文の最大金額（円）
LIVE_TRADE_MAX_ORDER_JPY=10000

# 月次損失リミット（%）— この割合を超えたら自動停止
LIVE_TRADE_MONTHLY_LOSS_LIMIT_PCT=10.0

# 取引対象シンボル
LIVE_TRADE_SYMBOL=BTC/JPY
