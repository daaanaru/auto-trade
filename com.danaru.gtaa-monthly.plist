<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.danaru.gtaa-monthly</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>/Users/mm16/だーなるAIカンパニー/50_ラボ/auto-trade/gtaa_live.py</string>
        <string>--rebalance</string>
    </array>
    <key>WorkingDirectory</key>
    <string>/Users/mm16/だーなるAIカンパニー/50_ラボ/auto-trade</string>
    <!-- 毎月1日 JST 01:00 に実行 (前月末のデータで判定) -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Day</key>
        <integer>1</integer>
        <key>Hour</key>
        <integer>1</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>/Users/mm16/だーなるAIカンパニー/50_ラボ/auto-trade/logs/gtaa-monthly.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/mm16/だーなるAIカンパニー/50_ラボ/auto-trade/logs/gtaa-monthly_error.log</string>
    <key>RunAtLoad</key>
    <false/>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
        <key>PYTHONPATH</key>
        <string>/Users/mm16/だーなるAIカンパニー/50_ラボ/auto-trade</string>
        <!-- Discord Webhook URL は上様が ~/.zshrc または .env に設定 -->
        <!-- <key>DISCORD_WEBHOOK_URL</key> -->
        <!-- <string>https://discord.com/api/webhooks/...</string> -->
    </dict>
</dict>
</plist>
