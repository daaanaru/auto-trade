<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.danaru.turtle-daily</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>/Users/mm16/だーなるAIカンパニー/50_ラボ/auto-trade/turtle_live.py</string>
        <string>--check</string>
    </array>
    <key>WorkingDirectory</key>
    <string>/Users/mm16/だーなるAIカンパニー/50_ラボ/auto-trade</string>
    <!-- 毎朝 JST 07:00 に実行 (前日の米ETF close と crypto 日足確定後) -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>7</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>/Users/mm16/だーなるAIカンパニー/50_ラボ/auto-trade/logs/turtle-daily.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/mm16/だーなるAIカンパニー/50_ラボ/auto-trade/logs/turtle-daily_error.log</string>
    <key>RunAtLoad</key>
    <false/>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
        <key>PYTHONPATH</key>
        <string>/Users/mm16/だーなるAIカンパニー/50_ラボ/auto-trade</string>
        <!-- Discord Webhook URL は上様が ~/.zshrc または .env に設定 -->
    </dict>
</dict>
</plist>
